############################################################
# IMPORTANT: This is an example file. Do not use it as-is. #
# Use this as a reference point for your .env file.        #
# While you *can* use any .env variant, it is strongly     #
# recommended to use .env for compatibility with           #
# drizzle-kit and other tools.                             #
############################################################
# PostgreSQL
POSTGRES_USER=openboxoffice
POSTGRES_PASSWORD=openboxoffice
POSTGRES_DB=openboxoffice
DATABASE_URL=postgresql://openboxoffice:openboxoffice@localhost:5432/openboxoffice

# Redis
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=changemeplease # CHANGE THIS TO A RANDOM STRING (use openssl rand -base64 32)
BETTER_AUTH_URL=http://localhost:3000 # if in production, use the actual URL of your server
HOSTED=false # when true, "/" renders the marketing site instead of redirecting through the auth proxy

# Mailpit
MP_SMTP_AUTH_ACCEPT_ANY=1
MP_SMTP_AUTH_ALLOW_INSECURE=1
MP_DATABASE=/data/mailpit.db

# WITHOUT THIS, YOU WILL NOT BE ABLE TO SEND ANY EMAILS. THIS IS NECESSARY!
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM="OpenBoxOffice <noreply@openboxoffice.local>"

# Hosted version of OpenBoxOffice (also FOSS!)
# little functionality change, only intended as
# true for hosted version (w/ marketing, stripe connect, etc.)
HOSTED=false
